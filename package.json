{
  "name": "ipl-fantasy-calculator",
  "version": "1.0.0",
  "description": "IPL Fantasy Score Calculator - Scrapes live match data and calculates player points automatically",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "demo": "node demo.js",
    "scrape": "node services/scraper.js",
    "update": "node services/liveUpdater.js",
    "server": "node server.js",
    "dev": "nodemon server.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:dashboard": "playwright test tests/dashboard.spec.ts",
    "test:room": "playwright test tests/room.spec.ts",
    "test:team": "playwright test tests/team.spec.ts",
    "test:leaderboard": "playwright test tests/leaderboard.spec.ts",
    "test:e2e": "playwright test tests/e2e-integration.spec.ts",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "IPL",
    "Cricket",
    "Auction",
    "Fantasy",
    "API",
    "Live Updates"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-jwt": "^8.4.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^6.3.0",
    "nodemon": "^3.0.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
